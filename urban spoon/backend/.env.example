# Backend environment variables
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/your-db-name?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
PORT=3000
# Optional: limit CORS to your frontend domain in production
CORS_ORIGIN=https://your-frontend-domain.com

# Forgot password email settings (SMTP)
FRONTEND_URL=https://your-frontend-domain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
SMTP_FROM="Urban Spoon <your_email@example.com>"
APP_NAME=Urban Spoon
